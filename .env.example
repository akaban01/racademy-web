# Copy this file to .env for local `netlify dev` testing.
# Real values go here locally, and in the Netlify dashboard (Site configuration
# > Environment variables) for production. Never commit actual keys.

# Stripe API keys (Developers > API keys in the Stripe dashboard)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Signing secret from the Event destination / webhook endpoint
# (Developers > Webhooks > your endpoint > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs from Stripe Dashboard > Product catalog
# Create one Product+Price per item so amounts can change without a redeploy.
STRIPE_PRICE_APPLICATION_FEE=price_REPLACE_ME
STRIPE_PRICE_TRANSCRIPT_OFFICIAL=price_REPLACE_ME
STRIPE_PRICE_TRANSCRIPT_ELECTRONIC=price_REPLACE_ME
STRIPE_PRICE_TRANSCRIPT_UNOFFICIAL=price_REPLACE_ME

# Used to build Checkout success/cancel redirect URLs
SITE_URL=https://racademy.org
